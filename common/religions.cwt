types = {
    type[religion] = {
        path = "game/common/religions"

        localisation = {
            name = "$"
            description = "desc_$"
        }
    }
}

enums = {
    enum[religion_category] = {
        pantheon
        sages
    }
}

religion = {
    color = colour_field

    modifier = {
        alias_name[modifier] = alias_match_left[modifier]
    }

    religion_category = enum[religion_category]
}