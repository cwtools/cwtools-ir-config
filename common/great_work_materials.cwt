types = {
    type[great_work_material] = {
        path = "game/common/great_work_materials"

        localisation = {
            name = "$"
        }
    }
}

great_work_material = {
    icon = icon[gfx/interface/icons/great_work/materials]
    great_work_prestige = int
    great_work_trade_good = <trade_goods>
    ### Values use a trailing f, e.g. { 0.40f 0.0f }
    great_work_uv_offset = {
        ## cardinality = 2..2
        scalar
    }
}