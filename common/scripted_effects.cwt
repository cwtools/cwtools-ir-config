alias[effect:<scripted_effect>] = yes

# Parametrized invocation: my_effect = { PARAM = value }
alias[effect:<scripted_effect>] = {
    ## cardinality = 0..inf
    scalar = scalar
}

types = {
    type[scripted_effect] = {
        path = "game/common/scripted_effects"
    }
}

scripted_effect = {
    ## cardinality = 1..inf
    alias_name[effect] = alias_match_left[effect]
}